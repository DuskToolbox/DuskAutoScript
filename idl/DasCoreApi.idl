    //=============================================================================

    [ export, c_abi ] DasResult CreateIDasGuidVector(
        const DasGuid*                               p_data,
        size_t                                       size,
        [out] Das::ExportInterface::IDasGuidVector** pp_out_guid);

    [ export, c_abi ] DasResult CreateIDasStringVector(
        [out] Das::ExportInterface::IDasStringVector * *pp_out_vector);

    //=============================================================================
    // Plugin manager
    //=============================================================================

    [ export, c_abi ] DasResult InitializeIDasPluginManager(
        Das::ExportInterface::IDasReadOnlyGuidVector * p_ignore_plugins_guid,
        Das::ExportInterface::IDasInitializeIDasPluginManagerCallback
            * p_on_finished,
        [out] Das::ExportInterface::IDasInitializeIDasPluginManagerWaiter
            * *pp_out_waiter);

    //=============================================================================
