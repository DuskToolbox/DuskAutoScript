// DasCoreApi.idl — C ABI 接口（对齐 DasApi.h）
// 生成 DasCoreApi.generated.h，供 C++ 代码使用

// Log level constants for DasSetLogLevel()
defines DasLogLevel{
    DAS_LOG_LEVEL_TRACE = 0,
    DAS_LOG_LEVEL_DEBUG = 1,
    DAS_LOG_LEVEL_INFO = 2,
    DAS_LOG_LEVEL_WARN = 3,
    DAS_LOG_LEVEL_ERROR = 4,
    DAS_LOG_LEVEL_CRITICAL = 5,
    DAS_LOG_LEVEL_OFF = 6,
}

module
{

    //=============================================================================
    // JSON
    //=============================================================================

    [ export, c_abi ] DasResult ParseDasJsonFromString(
        const char*                            p_u8_string,
        [out] Das::ExportInterface::IDasJson** pp_out_json);

    [ export, c_abi ] DasResult
        CreateEmptyDasJson([out] Das::ExportInterface::IDasJson * *pp_out_json);

    //=============================================================================
    // VariantVector
    //=============================================================================

    [ export, c_abi ] DasResult CreateIDasVariantVector(
        [out] Das::ExportInterface::IDasVariantVector * *pp_out_vector);

    //=============================================================================
    // PortMap
    //=============================================================================

    [ export, c_abi ] DasResult CreateIDasPortMap(
        [out] Das::ExportInterface::IDasPortMap * *pp_out_port_map);

    //=============================================================================
    // Logging (U8 string variants)
    //=============================================================================

    [ export, c_abi ] void DasLogInfoU8(const char* p_string);

    [ export, c_abi ] void DasLogWarningU8(const char* p_string);

    [ export, c_abi ] void DasLogErrorU8(const char* p_string);

    [ export, c_abi ] void DasLogDebugU8(const char* p_string);

    //=============================================================================
    // Logging with source location
    //=============================================================================

    [ export, c_abi ] void DasLogDebugU8WithSourceLocation(
        const char*                               p_string,
        Das::ExportInterface::IDasSourceLocation* p_source_location);

    [ export, c_abi ] void DasLogInfoU8WithSourceLocation(
        const char*                               p_string,
        Das::ExportInterface::IDasSourceLocation* p_source_location);

    [ export, c_abi ] void DasLogWarningU8WithSourceLocation(
        const char*                               p_string,
        Das::ExportInterface::IDasSourceLocation* p_source_location);

    [ export, c_abi ] void DasLogErrorU8WithSourceLocation(
        const char*                               p_string,
        Das::ExportInterface::IDasSourceLocation* p_source_location);

    //=============================================================================
    // Error messages
    //=============================================================================

    [ export, c_abi ] DasResult DasGetErrorMessage(
        IDasTypeInfo * p_error_generator,
        DasResult error_code,
        [out] IDasReadOnlyString * *pp_out_error_message);

    [ export, c_abi ] DasResult DasGetPredefinedErrorMessage(
        DasResult error_code,
        [out] IDasReadOnlyString * *pp_out_error_message);

    //=============================================================================
    // Locale
    //=============================================================================

    [ export,
      c_abi ] DasResult DasSetDefaultLocale(IDasReadOnlyString * locale_name);

    [
        export,
        c_abi
    ] DasResult DasGetDefaultLocale([out] IDasReadOnlyString * *pp_out_locale);

    //=============================================================================
