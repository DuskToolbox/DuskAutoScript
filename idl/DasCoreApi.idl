    [ export, c_abi ] DasResult CreateIDasImageFromDecodedData(
        const DasImageDesc*                     p_desc,
        const DAS::ExportInterface::DasSize*    p_size,
        [out] Das::ExportInterface::IDasImage** pp_out_image);

    [ export, c_abi ] DasResult CreateIDasImageFromRgb888(
        Das::ExportInterface::IDasMemory * p_alias_memory,
        const DAS::ExportInterface::DasSize*    p_size,
        [out] Das::ExportInterface::IDasImage** pp_out_image);

    [ export, c_abi ] DasResult DasPluginLoadImageFromResource(
