    [ export, c_abi ] DasResult DasQueryMainProcessInterface(
        const DasGuid&   iid,
        [out] IDasBase** pp_out_object);

    [ export, c_abi ] DasResult DasRegisterMainProcessService(
        IDasBase * p_object,
        const DasGuid& iid);

    [ export, c_abi ] DasResult DasUnregisterMainProcessService(
        const DasGuid& iid);

    [ export, c_abi ] DasResult DasQueryMainProcessInterfaceByName(
        const char*      name,
        [out] IDasBase** pp_out_object);

    [ export, c_abi ] DasResult DasRegisterMainProcessServiceByName(
        IDasBase * p_object,
        const DasGuid& iid,
        const char*    name);

    [ export, c_abi ] DasResult DasUnregisterMainProcessServiceByName(
        const char* name);

    //=============================================================================
    // Log level
    //=============================================================================

    [ export, c_abi ] void DasSetLogLevel(int level);

    //=============================================================================
    // Core services factory
    //=============================================================================

    [ export, c_abi ] DasResult CreateIDasCoreServices(
        IDasReadOnlyString * p_settings_dir,
        IDasReadOnlyString * p_plugin_dir,
        IIpcContext * p_ipc_context,
